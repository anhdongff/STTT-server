# use sqlite (no redis, no postgres)
USE_SQLITE=true

# Postgres settings (IGNORED if USE_SQLITE=true)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=stttdb
POSTGRES_PORT=5433

# Redis port on host (IGNORED if USE_SQLITE=true)
REDIS_PORT=6380

# If set to "true" the startup script will execute `data_service/schema.sql` inside the Postgres container
# to recreate the `sttt` schema from scratch. Useful for local development. Set to "false" to skip.
# WARNING: this will DROP and recreate the schema (destructive). Only set to "true" if schema not already initialized or if you don't care about losing data.
# (IGNORED if USE_SQLITE=true)
RUN_DB_INIT=false

# Redis host (useful if Redis runs on a different host)
REDIS_HOST=localhost

# JWT / API settings
# Secret used to sign JWTs. MUST be changed in production.
JWT_SECRET=change-me-in-prod
# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256
# Token lifetime in minutes
JWT_EXP_MINUTES=60

# Login lock settings (for rate-limiting / temporary account lock)
# Number of failed attempts before locking account
LOGIN_LOCK_THRESHOLD=5
# Window (seconds) to count failed attempts (e.g. 900 = 15 minutes)
LOGIN_LOCK_WINDOW_SECONDS=900
# Duration (seconds) of the lock when threshold exceeded
LOGIN_LOCK_DURATION_SECONDS=900

# Worker settings
# whether the worker should wait for the job to be done before take another job
WAIT_FOR_JOB_DONE=false

# Whisper model
# Model name: 'Systran/faster-whisper-medium', 'large-v3'
WHISPER_MODEL=Systran/faster-whisper-medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=6
# NLLB model
# Model name: 'facebook/nllb-200-distilled-600M', 'facebook/nllb-200-distilled-1.3B'
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_NUM_BEAMS=2

HF_TOKEN=

# Threshold (in seconds) to consider a job "small"
SMALL_JOB_THRESHOLD_SECONDS=300

# Number of small jobs to run in parallel per large job (e.g. if 4, then for each large job, up to 4 small jobs can run in parallel)
SMALL_PER_LARGE_CHILD_JOB = 4
